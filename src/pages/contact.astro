---
import Base from '../layouts/Base.astro';
import { ContactPage } from '../components/pages/ContactPage';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'contact');
const d = page.data;
---

<Base title={d.seo_title ?? d.title} description={d.seo_description}>
  <ContactPage
    client:load
    heroLabel={d.hero_label}
    heroHeading={d.hero_heading}
    heroSubheading={d.hero_subheading}
    email={d.email}
    phone={d.phone}
    phoneDisplay={d.phone_display}
    address={d.address}
    hours={d.hours}
    mapEmbedUrl={d.map_embed_url}
  />
</Base>
