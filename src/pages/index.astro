---
import Base from '../layouts/Base.astro';
import { HomePage } from '../components/home/HomePage';
import { getEntry, getCollection } from 'astro:content';

const page = await getEntry('pages', 'home');
const d = page.data;

const testimonials = (await getCollection('testimonials', (entry) => entry.data.locale === 'en'))
  .map((e) => e.data)
  .sort((a, b) => (a.order ?? 100) - (b.order ?? 100));
---

<Base title={d.seo_title ?? d.title} description={d.seo_description}>
  <HomePage
    client:load
    heroLabel={d.hero_label}
    heroHeading={d.hero_heading}
    heroSubheading={d.hero_subheading}
    heroImage={d.hero_image}
    heroImageAlt={d.hero_image_alt}
    heroCtaText={d.hero_cta_text}
    heroCtaUrl={d.hero_cta_url}
    heroButtonText={d.hero_button_text}
    heroButtonUrl={d.hero_button_url}
    loyaltyText={d.loyalty_text}
    loyaltyCtaText={d.loyalty_cta_text}
    loyaltyCtaUrl={d.loyalty_cta_url}
    interiorImage={d.interior_image}
    interiorImageAlt={d.interior_image_alt}
    interiorHeading={d.interior_heading}
    interiorSubheading={d.interior_subheading}
    welcomeHeading={d.welcome_heading}
    welcomeSubheading={d.welcome_subheading}
    welcomeBody={d.welcome_body}
    offerings={d.offerings}
    testimonials={testimonials}
    featuredProduct={d.featured_product}
    ctaHeading={d.cta_heading}
    ctaText={d.cta_text}
    finalCtaImage={d.final_cta_image}
    finalCtaImageAlt={d.final_cta_image_alt}
  />
</Base>
