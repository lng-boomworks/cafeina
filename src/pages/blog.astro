---
import Base from '../layouts/Base.astro';
import { BlogPage } from '../components/pages/BlogPage';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'blog');
const d = page.data;
---

<Base title={d.seo_title ?? d.title} description={d.seo_description}>
  <BlogPage
    client:load
    heroLabel={d.hero_label}
    heroHeading={d.hero_heading}
    heroSubheading={d.hero_subheading}
    introHeading={d.intro_heading}
    introBody={d.intro_body}
    introImage={d.intro_image}
    introImageAlt={d.intro_image_alt}
    ctaHeading={d.cta_heading}
    ctaText={d.cta_text}
  />
</Base>
